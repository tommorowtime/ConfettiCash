ScreenManager:
    WelcomeScreen:
    SignInScreen:
    OnBoardingScreen:
    InfoScreen:
    PlanScreen:
    MainScreen:
<WelcomeScreen>:
    name: "welcome"


    MDLabel:
        text: "Welcome to Confetti Cash"
        halign: "center"
        font_style: "H4"  # Makes the text larger and sleeker
        pos_hint: {"center_x": 0.5, "center_y": 0.6}

    MDLabel:
        text: "Every Win Needs Confetti!"
        halign: "center"
        font_style: "Subtitle1"  # Creates a nice visual hierarchy
        theme_text_color: "Secondary" # Dims the subtitle slightly
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

    MDRaisedButton:
        text: "Sign Up"
        pos_hint: {"center_x": 0.5, "center_y": 0.35}
        on_release: root.manager.current = "sign in"

<SignInScreen>:
    name: "sign in"

    MDLabel:
        text: "Sign Up"
        halign: "center"
        font_style: "H4"
        pos_hint: {"center_x": 0.5, "center_y": 0.85}

    MDTextField:
        id: email_field
        hint_text: "Enter email address:"
        helper_text: "Example: patrick.pam@confetticash.com"
        helper_text_mode: "on_focus"
        icon_right: "account"
        mode: "rectangle"
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5, "center_y": 0.7}

    MDTextField:
        id: password_field
        hint_text: "Create password:"
        helper_text: "Example: HelloWorld123"
        helper_text_mode: "on_focus"
        icon_right: "key-variant"
        password: True
        mode: "rectangle"
        size_hint_x: 0.8
        pos_hint: {"center_x": 0.5, "center_y": 0.55}

    # Terms & Conditions Checkboxes
    MDBoxLayout:
        orientation: "vertical"
        adaptive_size: True
        spacing: "8dp"
        pos_hint: {"center_x": 0.5, "center_y": 0.38}

        MDBoxLayout:
            orientation: "horizontal"
            adaptive_size: True
            spacing: "8dp"

            MDCheckbox:
                id: agree_checkbox
                group: "terms"  # Groups them so only one can be checked at a time
                size_hint: None, None
                size: "48dp", "48dp"
                on_active: app.on_checkbox_active(*args)

            MDLabel:
                text: "I agree to the Confetti Terms"
                adaptive_size: True
                pos_hint: {"center_y": 0.5}

        MDBoxLayout:
            orientation: "horizontal"
            adaptive_size: True
            spacing: "8dp"

            MDCheckbox:
                id: disagree_checkbox
                group: "terms"
                size_hint: None, None
                size: "48dp", "48dp"
                on_active: app.on_checkbox_active(*args)

            MDLabel:
                text: "I DO NOT agree to the Confetti Terms"
                adaptive_size: True
                pos_hint: {"center_y": 0.5}

    MDRaisedButton:
        text: "Submit"
        size_hint_x: 0.5
        pos_hint: {"center_x": 0.5, "center_y": 0.22}
        on_release: root.manager.current = "info"

    MDFlatButton:
        text: "Back to Home"
        theme_text_color: "Hint"
        pos_hint: {"center_x": 0.5, "center_y": 0.12}
        on_release: root.manager.current = "welcome"


<InfoScreen>:
    name: "info"

    MDBoxLayout:
        orientation: "vertical"
        spacing: "12dp"
        padding: "24dp"

        MDLabel:
            text: "We're Curious... Who are you?"
            font_style: "H5"
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]
            padding_y: "10dp"

        # A ScrollView ensures smaller phone screens don't cut off your fields
        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: "15dp"
                adaptive_height: True
                padding: "8dp"

                MDTextField:
                    hint_text: "Name:"
                    mode: "rectangle"

                MDTextField:
                    hint_text: "Age:"
                    input_filter: "int"  # Forces the keyboard to numbers only
                    mode: "rectangle"

                # Places City and State side-by-side
                MDGridLayout:
                    cols: 2
                    spacing: "15dp"
                    adaptive_height: True

                    MDTextField:
                        hint_text: "City:"
                        mode: "rectangle"

                    MDTextField:
                        hint_text: "State:"
                        mode: "rectangle"

                # Places Marital Status and Dependants side-by-side
                MDGridLayout:
                    cols: 2
                    spacing: "15dp"
                    adaptive_height: True

                    MDTextField:
                        hint_text: "Marital Status:"
                        mode: "rectangle"

                    MDTextField:
                        hint_text: "Any Dependants:"
                        input_filter: "int"
                        mode: "rectangle"

                MDLabel:
                    text: "Financial Literacy Confidence (1-5)"
                    halign: "center"
                    theme_text_color: "Secondary"
                    size_hint_y: None
                    height: self.texture_size[1]
                    padding_y: "15dp"


                # This label dynamically changes based on the slider
                MDLabel:
                    id: confidence_label
                    text: "Somewhat Confident"  # Default text because the slider starts at 3
                    font_style: "Subtitle1"
                    theme_text_color: "Primary"
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1]

    MDFloatLayout:  # Change this from MDBoxLayout
        MDSlider:
            pos_hint: {"center_x": .5, "center_y": .2}  # This will now work
            id: my_slider
            min: 0
            max: 100
            value: 0
            pos_hint: {"center_x": .5, "center_y": .2}
        MDRoundFlatButton:
            MDRaisedButton:
                text: "Next"
                pos_hint: {"center_x": 0.9}
                on_release: root.manager.current = "onboarding"

<OnBoardingScreen>:
    name: "onboarding"

    MDScrollView:
        MDBoxLayout:
            orientation: "vertical"
            spacing: "15dp"
            padding: "24dp"
            adaptive_height: True

            MDLabel:
                text: "Let's get something done"
                font_style: "H4"
                halign: "center"
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "What financial goals do you most resonate with?"
                font_style: "Subtitle1"
                theme_text_color: "Secondary"
                halign: "center"
                size_hint_y: None
                height: self.texture_size[1]
                padding_y: "10dp"

            # The "no pressure" button
            MDRectangleFlatButton:
                text: "I just don't know"
                pos_hint: {"center_x": 0.5}
                theme_text_color: "Hint"

            # 6 Common Financial Goals Grid
            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "5dp"

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDCheckbox:
                        size_hint: None, None
                        size: "48dp", "48dp"
                    MDLabel:
                        text: "Build an Emergency Fund"
                        pos_hint: {"center_y": .5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDCheckbox:
                        size_hint: None, None
                        size: "48dp", "48dp"
                    MDLabel:
                        text: "Pay Off Credit Card Debt"
                        pos_hint: {"center_y": .5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDCheckbox:
                        size_hint: None, None
                        size: "48dp", "48dp"
                    MDLabel:
                        text: "Save for Retirement"
                        pos_hint: {"center_y": .5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDCheckbox:
                        size_hint: None, None
                        size: "48dp", "48dp"
                    MDLabel:
                        text: "Save for a Down Payment"
                        pos_hint: {"center_y": .5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDCheckbox:
                        size_hint: None, None
                        size: "48dp", "48dp"
                    MDLabel:
                        text: "Invest in the Stock Market"
                        pos_hint: {"center_y": .5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDCheckbox:
                        size_hint: None, None
                        size: "48dp", "48dp"
                    MDLabel:
                        text: "Pay Off Student Loans"
                        pos_hint: {"center_y": .5}

            # The Expand Button
            MDFlatButton:
                text: "Not what you want? -> Click for more"
                theme_text_color: "Primary"
                pos_hint: {"center_x": 0.5}

            # The Submit Button
            MDRaisedButton:
                text: "Submit"
                pos_hint: {"center_x": 0.5}
                on_release: root.manager.current = "plan"
<PlanScreen>:
    name: "plan"

    MDScrollView:
        MDBoxLayout:
            orientation: "vertical"
            spacing: "10dp"
            padding: "24dp"
            adaptive_height: True

            MDLabel:
                text: "How does this sound?"
                font_style: "H4"
                halign: "center"
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "This is our suggested framework to tackle your finances."
                font_style: "Subtitle1"
                theme_text_color: "Secondary"
                halign: "center"
                size_hint_y: None
                height: self.texture_size[1]
                padding_y: "10dp"

            MDLabel:
                text: "Patrick's Plan"
                font_style: "H5"
                theme_text_color: "Primary"
                size_hint_y: None
                height: self.texture_size[1]
                padding_y: "10dp"

            # --- Immediate Actions ---
            MDLabel:
                text: "Immediate Actions"
                font_style: "Subtitle2"
                theme_text_color: "Hint"
                size_hint_y: None
                height: self.texture_size[1]

            MDBoxLayout:
                orientation: "horizontal"
                adaptive_height: True
                MDLabel:
                    text: "Create budgeting plan"
                    pos_hint: {"center_y": .5}
                MDIconButton:
                    icon: "chevron-down"
                    pos_hint: {"center_y": .5}

            MDBoxLayout:
                orientation: "horizontal"
                adaptive_height: True
                MDLabel:
                    text: "Pay essential bills"
                    pos_hint: {"center_y": .5}
                MDIconButton:
                    icon: "chevron-down"
                    pos_hint: {"center_y": .5}

            # --- Short-term Goals ---
            MDLabel:
                text: "Short-term Goals"
                font_style: "Subtitle2"
                theme_text_color: "Hint"
                size_hint_y: None
                height: self.texture_size[1]
                padding_y: "10dp"

            MDBoxLayout:
                orientation: "horizontal"
                adaptive_height: True
                MDCheckbox:
                    active: True
                    size_hint: None, None
                    size: "48dp", "48dp"
                    pos_hint: {"center_y": .5}
                MDLabel:
                    text: "Financial independence"
                    pos_hint: {"center_y": .5}

            MDBoxLayout:
                orientation: "horizontal"
                adaptive_height: True
                MDCheckbox:
                    active: True
                    size_hint: None, None
                    size: "48dp", "48dp"
                    pos_hint: {"center_y": .5}
                MDLabel:
                    text: "Emergency savings"
                    pos_hint: {"center_y": .5}

            # --- Long-term Goals ---
            MDLabel:
                text: "Long-term Goals"
                font_style: "Subtitle2"
                theme_text_color: "Hint"
                size_hint_y: None
                height: self.texture_size[1]
                padding_y: "10dp"

            MDBoxLayout:
                orientation: "horizontal"
                adaptive_height: True
                MDCheckbox:
                    active: True
                    size_hint: None, None
                    size: "48dp", "48dp"
                    pos_hint: {"center_y": .5}
                MDLabel:
                    text: "Investment"
                    pos_hint: {"center_y": .5}

            MDBoxLayout:
                orientation: "horizontal"
                adaptive_height: True
                MDCheckbox:
                    active: True
                    size_hint: None, None
                    size: "48dp", "48dp"
                    pos_hint: {"center_y": .5}
                MDLabel:
                    text: "Life/health insurance"
                    pos_hint: {"center_y": .5}

            MDRaisedButton:
                text: "Submit"
                pos_hint: {"center_x": 0.5}
                on_release: root.manager.current = "main"
<MainScreen>:
    name: "main"

    MDBoxLayout:
        orientation: "vertical"
        spacing: "20dp"
        padding: "24dp"

        # --- Top Dashboard Header ---
        MDBoxLayout:
            adaptive_height: True
            MDIconButton:
                icon: "menu"
                pos_hint: {"center_y": 0.5}
            MDLabel:
                text: "Dashboard"
                font_style: "H5"
                halign: "center"
                pos_hint: {"center_y": 0.5}
            MDIconButton:
                icon: "account-circle-outline"
                pos_hint: {"center_y": 0.5}

        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: "20dp"
                adaptive_height: True

                MDLabel:
                    text: "Welcome back, Patrick!"
                    font_style: "H4"
                    size_hint_y: None
                    height: self.texture_size[1]

                # --- Progress Bar Card ---
                MDCard:
                    orientation: "vertical"
                    padding: "16dp"
                    spacing: "10dp"
                    size_hint_y: None
                    height: "80dp"
                    elevation: 2
                    radius: [12, 12, 12, 12]
                    md_bg_color: app.theme_cls.bg_light

                    # --- Progress Bar & Confetti Wrapper ---
                    MDRelativeLayout:
                        size_hint_y: None
                        height: "30dp" # Gives the progress bar some breathing room

                        MDProgressBar:
                            id: progress
                            value: 0
                            color: app.theme_cls.primary_color
                            size_hint_x: 0.9
                            pos_hint: {"center_x": 0.5, "center_y": 0.5}
                            type: "determinate"

                        # The hidden GIF layered right on top
                        Image:
                            id: confetti_gif
                            source: "confetti.gif"
                            anim_delay: -1
                            opacity: 0
                            pos_hint: {"center_x": 0.9, "center_y": 0.5}
                            
                            # -- NEW SIZING LOGIC --
                            size_hint: 4.5, 10       # Increased from 1.2, 5
                            allow_stretch: True      # Forces Kivy to stretch the image
                            keep_ratio: True         # Prevents the GIF from looking squished

                # --- Next Steps ---
                MDLabel:
                    text: "Your Next Steps"
                    font_style: "H6"
                    size_hint_y: None
                    height: self.texture_size[1]
                    padding_y: "10dp"

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDIcon:
                        icon: "checkbox-blank-circle-outline"
                        theme_text_color: "Hint"
                        pos_hint: {"center_y": 0.5}
                    MDLabel:
                        text: " First Step to Cash"
                        pos_hint: {"center_y": 0.5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDIcon:
                        icon: "checkbox-blank-circle-outline"
                        theme_text_color: "Hint"
                        pos_hint: {"center_y": 0.5}
                    MDLabel:
                        text: " Second Step to Glory"
                        pos_hint: {"center_y": 0.5}

                MDBoxLayout:
                    orientation: "horizontal"
                    adaptive_height: True
                    MDIcon:
                        icon: "checkbox-blank-circle-outline"
                        theme_text_color: "Hint"
                        pos_hint: {"center_y": 0.5}
                    MDLabel:
                        text: " Third Step to Confetti"
                        pos_hint: {"center_y": 0.5}